{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://imagevault.ai",
          "https://*.imagevault.ai",
          "http://localhost:3000"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": [
          "Content-Type",
          "Content-Length",
          "x-amz-content-sha256",
          "x-amz-date",
          "authorization"
        ]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
