{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/deploy-workers-on-merge.sh",
            "if": "Bash(gh pr merge *)",
            "timeout": 120,
            "statusMessage": "Deploying affected workers..."
          }
        ]
      }
    ]
  }
}
