{
  "name": "image-vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "cf-typegen": "wrangler types",
    "deploy:worker": "wrangler deploy --config pipeline-worker/wrangler.toml",
    "worker:dev": "wrangler dev --config pipeline-worker/wrangler.toml",
    "deploy:ai-cron": "wrangler deploy --config ai-cron-worker/wrangler.toml",
    "ai-cron:dev": "wrangler dev --config ai-cron-worker/wrangler.toml"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "next": "^15.5.2",
    "otpauth": "^9.5.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260228.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.67.0"
  }
}
